#: locales/command_strings.py:10
msgid "A Discord timestamp to fire at, e.g. a <t:...> tag. Overrides the time in 'when'."
msgstr "Μια χρονοσφραγίδα Discord για ενεργοποίηση, π.χ. μια ετικέτα <t:...>. Παρακάμπτει την ώρα στο 'when'."

#: locales/command_strings.py:11
msgid "A channel/category that should earn no XP."
msgstr "Ένα κανάλι/κατηγορία που δεν πρέπει να κερδίζει XP."

#: locales/command_strings.py:12
msgid "A channel/category to boost (omit for a role or server-wide boost)."
msgstr "Ένα κανάλι/κατηγορία για ενίσχυση (παράλειψέ το για ενίσχυση ρόλου ή ολόκληρου του διακομιστή)."

#: locales/command_strings.py:13
msgid "A custom message on the verify embed."
msgstr "Ένα προσαρμοσμένο μήνυμα στο embed επαλήθευσης."

#: locales/command_strings.py:14
msgid "A name for the new server playlist."
msgstr "Ένα όνομα για τη νέα playlist του διακομιστή."

#: locales/command_strings.py:15
msgid "A role that should earn no XP."
msgstr "Ένας ρόλος που δεν πρέπει να κερδίζει XP."

#: locales/command_strings.py:16
msgid "A role to boost (omit for a channel or server-wide boost)."
msgstr "Ένας ρόλος για ενίσχυση (παράλειψέ το για ενίσχυση καναλιού ή ολόκληρου του διακομιστή)."

#: locales/command_strings.py:17
msgid "A song name or URL to search for and play."
msgstr "Ένα όνομα τραγουδιού ή URL για αναζήτηση και αναπαραγωγή."

#: locales/command_strings.py:18
msgid "A song to search for and save (defaults to the current track)."
msgstr "Ένα τραγούδι για αναζήτηση και αποθήκευση (προεπιλογή το τρέχον κομμάτι)."

#: locales/command_strings.py:19
msgid "A timestamp (1:23 or 1:02:03), whole seconds (90), or a relative +30 / -15."
msgstr "Μια χρονοσφραγίδα (1:23 ή 1:02:03), ακέραια δευτερόλεπτα (90), ή σχετική +30 / -15."

#: locales/command_strings.py:20
msgid "Add a member to the live-alert watchlist (channel is an optional override)."
msgstr "Πρόσθεσε ένα μέλος στη λίστα παρακολούθησης ειδοποιήσεων live (το κανάλι είναι προαιρετική παράκαμψη)."

#: locales/command_strings.py:21
msgid "Add a user to the bot-wide blacklist."
msgstr "Πρόσθεσε έναν χρήστη στη μαύρη λίστα ολόκληρου του bot."

#: locales/command_strings.py:22
msgid "Admin XP tools: give, take, set, or reset a member's XP."
msgstr "Εργαλεία διαχειριστή για XP: δώσε, αφαίρεσε, όρισε, ή επανάφερε το XP ενός μέλους."

#: locales/command_strings.py:23
msgid "Apply an audio effect preset to the current playback (Off to clear)."
msgstr "Εφάρμοσε ένα προκαθορισμένο εφέ ήχου στην τρέχουσα αναπαραγωγή (Off για εκκαθάριση)."

#: locales/command_strings.py:24
msgid "Assign an auto-role to your guild."
msgstr "Όρισε έναν αυτόματο ρόλο στον διακομιστή σου."

#: locales/command_strings.py:25
msgid "Ban a member from the server."
msgstr "Κάνε ban σε ένα μέλος από τον διακομιστή."

#: locales/command_strings.py:26
msgid "Be the first to retype the given sentence as fast as you can."
msgstr "Γίνε ο πρώτος που θα ξαναγράψει τη δοσμένη πρόταση όσο πιο γρήγορα μπορείς."

#: locales/command_strings.py:27
msgid "Boost or reduce XP (0-5x). Give a channel/category OR a role, or"
msgstr "Ενίσχυσε ή μείωσε το XP (0-5x). Δώσε ένα κανάλι/κατηγορία Ή έναν ρόλο, ή"

#: locales/command_strings.py:28
msgid "Browse anime from a season (defaults to the current season)."
msgstr "Περιήγηση σε anime μιας σεζόν (προεπιλογή η τρέχουσα σεζόν)."

#: locales/command_strings.py:29
msgid "Browse the anime trending on AniList right now."
msgstr "Περιήγηση στα anime που είναι trending στο AniList αυτή τη στιγμή."

#: locales/command_strings.py:30
msgid "Browse the most popular anime on AniList."
msgstr "Περιήγηση στα πιο δημοφιλή anime στο AniList."

#: locales/command_strings.py:31
msgid "Browse tracks, albums, artists and playlists, and queue any of them."
msgstr "Περιήγηση σε κομμάτια, άλμπουμ, καλλιτέχνες και playlists, και βάλε οποιοδήποτε στην ουρά."

#: locales/command_strings.py:32
msgid "Build a Google reverse image search link for an image URL or attachment."
msgstr "Δημιούργησε έναν σύνδεσμο αντίστροφης αναζήτησης εικόνας Google για ένα URL εικόνας ή συνημμένο."

#: locales/command_strings.py:33
msgid "Clear the upcoming queue while the current track keeps playing."
msgstr "Άδειασε την επερχόμενη ουρά ενώ το τρέχον κομμάτι συνεχίζει να παίζει."

#: locales/command_strings.py:34
msgid "Clear your entire gaming profile."
msgstr "Διάγραψε ολόκληρο το προφίλ gaming σου."

#: locales/command_strings.py:35
msgid "Configure this server's warn escalation rules (threshold -> action)."
msgstr "Ρύθμισε τους κανόνες κλιμάκωσης warns αυτού του διακομιστή (όριο -> ενέργεια)."

#: locales/command_strings.py:36
msgid "Create a Live streamer role and link it to the alert config."
msgstr "Δημιούργησε έναν ρόλο Live streamer και σύνδεσέ τον με τη ρύθμιση ειδοποιήσεων."

#: locales/command_strings.py:37
msgid "Create a native yes/no poll (runs for 24 hours)."
msgstr "Δημιούργησε μια εγγενή δημοσκόπηση ναι/όχι (διαρκεί 24 ώρες)."

#: locales/command_strings.py:38
msgid "Create or re-enable an AniList feed on a channel (default: here)."
msgstr "Δημιούργησε ή ενεργοποίησε ξανά μια ροή AniList σε ένα κανάλι (προεπιλογή εδώ)."

#: locales/command_strings.py:39
msgid "Delete a button-role panel by its message ID (strips the buttons)."
msgstr "Διάγραψε έναν πίνακα button-role με βάση το ID του μηνύματός του (αφαιρεί τα κουμπιά)."

#: locales/command_strings.py:40
msgid "Delete a feed and its follows (default: this channel)."
msgstr "Διάγραψε μια ροή και τις παρακολουθήσεις της (προεπιλογή αυτό το κανάλι)."

#: locales/command_strings.py:41
msgid "Delete a number of a member's recent messages."
msgstr "Διάγραψε έναν αριθμό πρόσφατων μηνυμάτων ενός μέλους."

#: locales/command_strings.py:42
msgid "Delete a number of recent messages in this channel."
msgstr "Διάγραψε έναν αριθμό πρόσφατων μηνυμάτων σε αυτό το κανάλι."

#: locales/command_strings.py:43
msgid "Delete a shared server playlist (its creator or a moderator only)."
msgstr "Διάγραψε μια κοινόχρηστη playlist του διακομιστή (μόνο ο δημιουργός της ή ένας συντονιστής)."

#: locales/command_strings.py:44
msgid "Delete the Live streamer role and unlink it from the config."
msgstr "Διάγραψε τον ρόλο Live streamer και αποσύνδεσέ τον από τη ρύθμιση."

#: locales/command_strings.py:45
msgid "Disable moderation logging for this guild."
msgstr "Απενεργοποίησε την καταγραφή διαχείρισης για αυτόν τον διακομιστή."

#: locales/command_strings.py:46
msgid "Disable the starboard and wipe its configuration for this guild."
msgstr "Απενεργοποίησε το starboard και διάγραψε τη ρύθμισή του για αυτόν τον διακομιστή."

#: locales/command_strings.py:47
msgid "Disable the welcome message for your guild."
msgstr "Απενεργοποίησε το μήνυμα καλωσορίσματος για τον διακομιστή σου."

#: locales/command_strings.py:48
msgid "Disconnect a member from their voice channel."
msgstr "Αποσύνδεσε ένα μέλος από το φωνητικό κανάλι του."

#: locales/command_strings.py:49
msgid "Disconnect the player from the voice channel."
msgstr "Αποσύνδεσε τον player από το φωνητικό κανάλι."

#: locales/command_strings.py:50
msgid "Edit a profile field through a guided form (radio picker + value)."
msgstr "Επεξεργάσου ένα πεδίο προφίλ μέσω καθοδηγούμενης φόρμας (επιλογέας radio + τιμή)."

#: locales/command_strings.py:51
msgid "Enable or disable the leveling system for this server."
msgstr "Ενεργοποίησε ή απενεργοποίησε το σύστημα επιπέδων για αυτόν τον διακομιστή."

#: locales/command_strings.py:52
msgid "Finish linking with the PIN code AniList gave you."
msgstr "Ολοκλήρωσε τη σύνδεση με τον κωδικό PIN που σου έδωσε το AniList."

#: locales/command_strings.py:53
msgid "Follow an AniList user in this server's feed."
msgstr "Ακολούθησε έναν χρήστη AniList στη ροή αυτού του διακομιστή."

#: locales/command_strings.py:54
msgid "Give a member XP (adds to their current total)."
msgstr "Δώσε XP σε ένα μέλος (προστίθεται στο τρέχον σύνολό του)."

#: locales/command_strings.py:55
msgid "Give a role to a member."
msgstr "Δώσε έναν ρόλο σε ένα μέλος."

#: locales/command_strings.py:56
msgid "Grant a role automatically when a member reaches a level."
msgstr "Παραχώρησε αυτόματα έναν ρόλο όταν ένα μέλος φτάνει σε ένα επίπεδο."

#: locales/command_strings.py:57
msgid "Guided update: pick the title by clicking, then edit a pre-filled form."
msgstr "Καθοδηγούμενη ενημέρωση: επίλεξε τον τίτλο κάνοντας κλικ, μετά επεξεργάσου μια προσυμπληρωμένη φόρμα."

#: locales/command_strings.py:58
msgid "How long the ban lasts, e.g. 1d or 2h30m."
msgstr "Πόσο διαρκεί το ban, π.χ. 1d ή 2h30m."

#: locales/command_strings.py:59
msgid "How long the event runs, e.g. 2h (max 14 days)."
msgstr "Πόσο διαρκεί η εκδήλωση, π.χ. 2h (μέγιστο 14 ημέρες)."

#: locales/command_strings.py:60
msgid "How many members to show (max 25, default 5)."
msgstr "Πόσα μέλη να εμφανιστούν (μέγιστο 25, προεπιλογή 5)."

#: locales/command_strings.py:61
msgid "How many messages to delete (1 to 999)."
msgstr "Πόσα μηνύματα να διαγραφούν (1 έως 999)."

#: locales/command_strings.py:62
msgid "How many messages to show (max 25, default 10)."
msgstr "Πόσα μηνύματα να εμφανιστούν (μέγιστο 25, προεπιλογή 10)."

#: locales/command_strings.py:63
msgid "How many of the member's messages to delete (max 500)."
msgstr "Πόσα μηνύματα του μέλους να διαγραφούν (μέγιστο 500)."

#: locales/command_strings.py:64
msgid "How many stars a message needs (default 3)."
msgstr "Πόσα αστέρια χρειάζεται ένα μήνυμα (προεπιλογή 3)."

#: locales/command_strings.py:65
msgid "How many stars a message needs to reach the starboard."
msgstr "Πόσα αστέρια χρειάζεται ένα μήνυμα για να φτάσει στο starboard."

#: locales/command_strings.py:66
msgid "How many warns to remove (default 1)."
msgstr "Πόσα warns να αφαιρεθούν (προεπιλογή 1)."

#: locales/command_strings.py:67
msgid "How much XP to add (1 to 1000000)."
msgstr "Πόσο XP να προστεθεί (1 έως 1000000)."

#: locales/command_strings.py:68
msgid "How much XP to remove (1 to 1000000)."
msgstr "Πόσο XP να αφαιρεθεί (1 έως 1000000)."

#: locales/command_strings.py:69
msgid "Interactively browse and remove a member's warnings."
msgstr "Περιήγηση και αφαίρεση των προειδοποιήσεων ενός μέλους διαδραστικά."

#: locales/command_strings.py:70
msgid "Join or leave this server's AniList feed with your linked account."
msgstr "Μπες ή φύγε από τη ροή AniList αυτού του διακομιστή με τον συνδεδεμένο λογαριασμό σου."

#: locales/command_strings.py:71
msgid "Jump to a position in the current track."
msgstr "Μετάβαση σε μια θέση στο τρέχον κομμάτι."

#: locales/command_strings.py:72
msgid "Kick a member from the server."
msgstr "Κάνε kick σε ένα μέλος από τον διακομιστή."

#: locales/command_strings.py:73
msgid "Leave empty for the all-time leaderboard, or pick weekly/monthly."
msgstr "Άφησέ το κενό για τον πίνακα κατάταξης όλων των εποχών, ή διάλεξε εβδομαδιαίο/μηνιαίο."

#: locales/command_strings.py:74
msgid "Link your AniList account and edit your lists."
msgstr "Σύνδεσε τον λογαριασμό σου AniList και επεξεργάσου τις λίστες σου."

#: locales/command_strings.py:75
msgid "List all reaction-role mappings for this guild."
