msgstr "Εμφάνιση των μηνυμάτων με τα περισσότερα αστέρια σε αυτό το guild."

#: locales/command_strings.py:129
msgid "Show your anime/manga list, filtered by status (defaults to CURRENT)."
msgstr "Εμφάνισε τη λίστα anime/manga σου, φιλτραρισμένη κατά κατάσταση (προεπιλογή CURRENT)."

#: locales/command_strings.py:130
msgid "Show your saved favourite tracks, or another member's."
msgstr "Εμφάνιση των αποθηκευμένων αγαπημένων κομματιών σου, ή ενός άλλου μέλους."

#: locales/command_strings.py:131
msgid "Shows Astronomy Picture of the Day."
msgstr "Εμφανίζει την Αστρονομική Εικόνα της Ημέρας."

#: locales/command_strings.py:132
msgid "Shows the bot's websocket latency."
msgstr "Εμφανίζει την καθυστέρηση websocket του bot."

#: locales/command_strings.py:133
msgid "Shows the current weather for a given city."
msgstr "Εμφανίζει τον τρέχοντα καιρό για μια δεδομένη πόλη."

#: locales/command_strings.py:134
msgid "Shows the ranked members of the guild."
msgstr "Εμφανίζει τα κατατεταγμένα μέλη του guild."

#: locales/command_strings.py:135
msgid "Shows your level and XP rank card, or another member's."
msgstr "Εμφανίζει την κάρτα επιπέδου και κατάταξης XP σου, ή ενός άλλου μέλους."

#: locales/command_strings.py:136
msgid "Shuffle the upcoming tracks in the queue."
msgstr "Ανακάτεμα των επόμενων κομματιών στην ουρά."

#: locales/command_strings.py:137
msgid "Simulate a join for yourself to preview the welcome."
msgstr "Προσομοίωση μιας εισόδου για τον εαυτό σου ώστε να δεις μια προεπισκόπηση του καλωσορίσματος."

#: locales/command_strings.py:138
msgid "Skip the current track and play the next one."
msgstr "Παράλειψη του τρέχοντος κομματιού και αναπαραγωγή του επόμενου."

#: locales/command_strings.py:139
msgid "Starboard related commands."
msgstr "Εντολές σχετικές με το starboard."

#: locales/command_strings.py:140
msgid "Start linking your AniList account."
msgstr "Ξεκίνησε τη σύνδεση του λογαριασμού σου AniList."

#: locales/command_strings.py:141
msgid "Stop following an AniList user (by stored name, case-insensitive)."
msgstr "Σταμάτα να ακολουθείς έναν χρήστη AniList (αποθηκευμένο όνομα, χωρίς διάκριση πεζών-κεφαλαίων)."

#: locales/command_strings.py:142
msgid "Stop playback and clear the queue (stays connected)."
msgstr "Διακοπή της αναπαραγωγής και εκκαθάριση της ουράς (παραμένει συνδεδεμένο)."

#: locales/command_strings.py:143
msgid "Tells you the newest members of the server."
msgstr "Σου λέει τα νεότερα μέλη του server."

#: locales/command_strings.py:144
msgid "Temporarily bans a member for the given duration."
msgstr "Απαγορεύει προσωρινά ένα μέλος για την δεδομένη διάρκεια."

#: locales/command_strings.py:145
msgid "The 1-based position of the favourite to remove."
msgstr "Η θέση (ξεκινώντας από το 1) του αγαπημένου προς αφαίρεση."

#: locales/command_strings.py:146
msgid "Translate text to English (auto-detect source language)."
msgstr "Μετάφραση κειμένου στα Αγγλικά (αυτόματος εντοπισμός γλώσσας προέλευσης)."

#: locales/command_strings.py:147
msgid "Turn off verification (existing buttons will report it is off)."
msgstr "Απενεργοποίησε την επαλήθευση (τα υπάρχοντα κουμπιά θα δηλώνουν ότι είναι απενεργοποιημένη)."

#: locales/command_strings.py:148
msgid "Un-mutes the specified member."
msgstr "Αναιρεί τη σίγαση του καθορισμένου μέλους."

#: locales/command_strings.py:149
msgid "Unbans a user. Requires ban members permission. Also bot must have this permission."
msgstr "Αίρει την απαγόρευση ενός χρήστη. Απαιτεί δικαίωμα απαγόρευσης μελών. Επίσης το bot πρέπει να έχει αυτό το δικαίωμα."

#: locales/command_strings.py:150
msgid "Unlink your AniList account."
msgstr "Αποσύνδεσε τον λογαριασμό σου AniList."

#: locales/command_strings.py:151
msgid "Update the amount of stars needed to reach the starboard."
msgstr "Ενημέρωση του αριθμού αστεριών που απαιτούνται για να φτάσει κάτι στο starboard."

#: locales/command_strings.py:152
msgid "Update the reason recorded on an existing case."
msgstr "Ενημέρωση του λόγου που έχει καταγραφεί σε μια υπάρχουσα υπόθεση."

#: locales/command_strings.py:153
msgid "Verification gate commands."
msgstr "Εντολές σχετικές με την πύλη επαλήθευσης."

#: locales/command_strings.py:154
msgid "View a member's gaming profile."
msgstr "Προβολή του προφίλ gaming ενός μέλους."

#: locales/command_strings.py:155
msgid "Volume level between 0 and 200 (100 is default)."
msgstr "Επίπεδο έντασης ήχου μεταξύ 0 και 200 (το 100 είναι η προεπιλογή)."

#: locales/command_strings.py:156
msgid "Warn a member of the guild (auto-kick at 3 warns)"
msgstr "Προειδοποίηση ενός μέλους του guild (αυτόματη αποβολή στις 3 προειδοποιήσεις)"

#: locales/command_strings.py:157
msgid "Whose favourites to show (defaults to you)."
msgstr "Ποιανού τα αγαπημένα να εμφανιστούν (προεπιλογή είσαι εσύ)."

#: locales/command_strings.py:158
msgid "all"
msgstr "όλα"

